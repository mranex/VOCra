{
  "ssim_filter": {
    "enabled": true,
    "threshold": 0.95
  },
  "segmenter": {
    "similarity_threshold": 0.5,
    "blank_tolerance": 1,
    "ssim_cross_check": true,
    "ssim_same_threshold": 0.7,
    "ssim_override_threshold": 0.9,
    "use_sharpness_representative": true,
    "use_text_voting": true
  },
  "final_ocr": {
    "provider": "llama_cpp",
    "server_url": "http://127.0.0.1:8080",
    "model": "paddleocr-vl",
    "timeout": 120,
    "temperature": 0,
    "max_tokens": 512,
    "prompt": "OCR:",
    "repeat_penalty": 1.2,
    "repeat_last_n": -1,
    "max_retries": 3,
    "clear_cache_interval": 1,
    "llama_cpp_dir": "tools/",
    "model_path": "models/paddleocr_vl/model.gguf",
    "mmproj_path": "models/paddleocr_vl/mmproj.gguf",
    "gpu_layers": 99,
    "ctx_size": 8192,
    "parallel_slots": 1,
    "chrome_lens_language": "auto",
    "chrome_lens_headless": true,
    "chrome_lens_max_retries": 3,
    "chrome_path": "",
    "user_data_dir": ""
  },
  "translator": {
    "enabled": false,
    "provider": "openai_compatible",
    "base_url": "",
    "api_key": "",
    "model": "",
    "source_lang": "auto",
    "target_lang": "vi",
    "batch_size": 300,
    "timeout": 120,
    "temperature": 0.3,
    "max_tokens": 4096,
    "style": "default",
    "custom_prompt": "",
    "json_mode": true,
    "max_retries": 2
  },
  "burn_video": {
    "ffmpeg_path": "",
    "blur_enabled": true,
    "blur_strength": 8,
    "style_preset": "balanced",
    "burn_style": {
      "font_family": "Arial",
      "font_size": 42,
      "bold": false,
      "italic": false,
      "primary_color": "#FFFFFF",
      "outline_color": "#000000",
      "shadow_color": "#000000",
      "opacity": 100,
      "outline_width": 2,
      "shadow_depth": 0,
      "alignment": "bottom_center",
      "margin_l": 40,
      "margin_r": 40,
      "margin_v": 40,
      "max_line_chars": 42,
      "position_mode": "screen"
    }
  }
}
